---
import Layout from '../layouts/Layout.astro';
import { news } from '../content/news';

const categoryColors: Record<string, string> = {
  资讯: "bg-blue-600",
  攻略: "bg-green-600",
  活动: "bg-yellow-600",
  二创: "bg-pink-600"
};
---

<Layout title="资讯">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-4">资讯站</h1>
    <p class="text-gray-400 mb-8">最新的游戏资讯、攻略、二创内容</p>

    <!-- News List -->
    <div class="space-y-6">
      {news.map((item) => (
        <article class="bg-gray-800 rounded-xl overflow-hidden hover:bg-gray-750 transition hover:transform hover:scale-[1.01]">
          <div class="p-6">
            <div class="flex flex-wrap items-center gap-4 mb-4">
              <span class={`px-4 py-2 rounded-full text-sm font-semibold ${categoryColors[item.category] || 'bg-gray-600'}`}>
                {item.category}
              </span>
              <span class="text-gray-400 text-sm flex items-center gap-1">
                <span>📅</span>
                {item.date}
              </span>
              <div class="flex gap-2 ml-auto">
                {item.tags?.map((tag) => (
                  <span class="px-2 py-1 bg-gray-700 rounded text-xs text-gray-400">#{tag}</span>
                ))}
              </div>
            </div>
            <h2 class="text-2xl font-bold mb-3 hover:text-xilian-purple transition">
              <a href="#">{item.title}</a>
            </h2>
            <p class="text-gray-300 mb-4">{item.excerpt}</p>
            <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-700">
              <a 
                href="#"
                class="px-6 py-2 bg-xilian-purple rounded-full hover:bg-xilian-purple/80 transition whitespace-nowrap font-medium"
              >
                阅读全文
              </a>
              <span class="text-gray-500 text-sm flex items-center gap-1">
                <span>👁️</span>
                {item.views || 0} 阅读
              </span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Pagination -->
    <div class="flex justify-center gap-2 mt-12">
      <button class="px-4 py-2 bg-gray-800 rounded hover:bg-gray-700 transition">上一页</button>
      <button class="px-4 py-2 bg-xilian-purple rounded">1</button>
      <button class="px-4 py-2 bg-gray-800 rounded hover:bg-gray-700 transition">2</button>
      <button class="px-4 py-2 bg-gray-800 rounded hover:bg-gray-700 transition">3</button>
      <button class="px-4 py-2 bg-gray-800 rounded hover:bg-gray-700 transition">下一页</button>
    </div>
  </div>
</Layout>
