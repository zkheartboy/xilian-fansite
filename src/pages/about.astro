---
import Layout from '../layouts/Layout.astro';
import { character } from '../content/characters';

const skillColors: Record<string, string> = {
  '战技': 'bg-blue-600',
  '终结技': 'bg-purple-600',
  '忆灵技': 'bg-pink-600',
  '被动': 'bg-gray-600',
  '普攻': 'bg-green-600'
};
---

<Layout title="角色介绍">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Character Header -->
    <div class="flex flex-col lg:flex-row gap-12 items-center mb-16">
      <div class="w-full lg:w-1/3">
        <div class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-xilian-purple via-xilian-pink to-xilian-blue rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
          <div class="relative w-full aspect-[2/3] bg-gradient-to-br from-xilian-purple/20 via-xilian-pink/20 to-xilian-blue/20 rounded-2xl flex items-center justify-center overflow-hidden">
            <div class="absolute inset-0 bg-[url('/images/hero.webp')] bg-cover bg-center opacity-80"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-transparent to-transparent"></div>
            <div class="relative z-10 text-center px-4">
              <h1 class="text-6xl font-bold mb-2 bg-gradient-to-r from-xilian-purple via-xilian-pink to-xilian-blue bg-clip-text text-transparent">
                {character.name}
              </h1>
              <p class="text-2xl text-gray-300 mb-4">{character.nameEn}</p>
              <p class="text-xl text-xilian-purple font-medium">{character.title}</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="w-full lg:w-2/3">
        <div class="flex flex-wrap gap-4 mb-6">
          <span class="px-5 py-2.5 bg-xilian-purple rounded-full text-lg font-semibold">⭐ {character.rarity}星</span>
          <span class="px-5 py-2.5 bg-xilian-blue rounded-full text-lg font-semibold">❄️ {character.element}</span>
          <span class="px-5 py-2.5 bg-xilian-pink rounded-full text-lg font-semibold">🔮 {character.path}</span>
        </div>
        
        <p class="text-xl text-gray-300 leading-relaxed mb-8">
          {character.description}
        </p>
        
        <div class="bg-gray-800/50 rounded-xl p-6 mb-8">
          <h3 class="text-lg font-bold text-gray-400 mb-4">配音阵容</h3>
          <div class="grid md:grid-cols-3 gap-4">
            <div class="flex items-center gap-3">
              <span class="text-2xl">🇨🇳</span>
              <div>
                <span class="text-gray-400 text-sm">中文</span>
                <p class="text-gray-200 font-medium">{character.cv.zh}</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-2xl">🇯🇵</span>
              <div>
                <span class="text-gray-400 text-sm">日文</span>
                <p class="text-gray-200 font-medium">{character.cv.ja}</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-2xl">🇺🇸</span>
              <div>
                <span class="text-gray-400 text-sm">英文</span>
                <p class="text-gray-200 font-medium">{character.cv.en}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Skills -->
    <section class="mb-16">
      <h2 class="text-4xl font-bold mb-8 text-center">技能介绍</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {character.skills.map((skill) => (
          <div class="bg-gray-800 rounded-xl p-6 hover:bg-gray-750 transition hover:transform hover:scale-[1.02]">
            <div class="flex justify-between items-center mb-4">
              <h3 class="text-2xl font-bold text-xilian-purple">{skill.name}</h3>
              <span class={`px-4 py-2 rounded-full text-sm font-semibold ${skillColors[skill.type] || 'bg-gray-600'}`}>
                {skill.type}
              </span>
            </div>
            <p class="text-gray-300 mb-4">{skill.description}</p>
            {skill.detail && (
              <div class="bg-gray-900/50 rounded-lg p-4 text-sm text-gray-400">
                <p class="font-medium text-gray-500 mb-2">技能详情：</p>
                <p>{skill.detail}</p>
              </div>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Story -->
    <section class="mb-16">
      <h2 class="text-4xl font-bold mb-8 text-center">背景故事</h2>
      <div class="space-y-6">
        {character.story.map((section, index) => (
          <div class="bg-gray-800 rounded-xl p-8 hover:bg-gray-750 transition">
            <h3 class="text-2xl font-bold text-xilian-purple mb-4">{section.title}</h3>
            <p class="text-gray-300 leading-relaxed text-lg">{section.content}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Quotes -->
    <section>
      <h2 class="text-4xl font-bold mb-8 text-center">角色语录</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {character.quotes.map((quote, index) => (
          <blockquote class="bg-gray-800 rounded-xl p-6 hover:bg-gray-750 transition group">
            <div class="flex items-center gap-2 mb-3">
              {quote.category && (
                <span class="px-3 py-1 bg-gray-700 rounded-full text-xs text-gray-400">
                  {quote.category}
                </span>
              )}
            </div>
            <p class="text-xl italic text-gray-300 mb-4 group-hover:text-xilian-purple transition">
              "{quote.text}"
            </p>
            <div class="flex items-center gap-2 text-gray-500 text-sm">
              <span>✨</span>
              <span>第 {index + 1} 句</span>
            </div>
          </blockquote>
        ))}
      </div>
    </section>
  </div>
</Layout>
