---
import Layout from '../layouts/Layout.astro';
---

<Layout title="首页">
  <!-- Hero Section -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-xilian-purple/20 to-gray-900"></div>
    <div class="absolute inset-0 bg-[url('https://picsum.photos/1920/1080?random=1')] bg-cover bg-center opacity-30"></div>
    
    <div class="relative z-10 text-center px-4">
      <h1 class="text-6xl md:text-8xl font-bold mb-4 bg-gradient-to-r from-xilian-purple via-xilian-pink to-xilian-blue bg-clip-text text-transparent">
        昔涟
      </h1>
      <p class="text-2xl md:text-3xl text-gray-300 mb-8">Xilian</p>
      <p class="text-lg text-gray-400 mb-12">来自星尘 · 阿尔林铎</p>
      <div class="flex gap-4 justify-center">
        <a href="/about" class="px-8 py-3 bg-xilian-purple rounded-full hover:bg-xilian-purple/80 transition">
          了解昔涟
        </a>
        <a href="/gallery" class="px-8 py-3 border border-xilian-purple rounded-full hover:bg-xilian-purple/20 transition">
          查看图库
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <h2 class="text-4xl font-bold text-center mb-12">网站导航</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <a href="/about" class="block p-8 bg-gray-800 rounded-2xl hover:bg-gray-700 transition group">
        <div class="text-4xl mb-4">👤</div>
        <h3 class="text-xl font-bold mb-2 group-hover:text-xilian-purple">角色介绍</h3>
        <p class="text-gray-400">了解昔涟的背景故事、技能特性</p>
      </a>
      <a href="/gallery" class="block p-8 bg-gray-800 rounded-2xl hover:bg-gray-700 transition group">
        <div class="text-4xl mb-4">🖼️</div>
        <h3 class="text-xl font-bold mb-2 group-hover:text-xilian-purple">图片库</h3>
        <p class="text-gray-400">海量高清壁纸、表情包</p>
      </a>
      <a href="/videos" class="block p-8 bg-gray-800 rounded-2xl hover:bg-gray-700 transition group">
        <div class="text-4xl mb-4">🎬</div>
        <h3 class="text-xl font-bold mb-2 group-hover:text-xilian-purple">视频库</h3>
        <p class="text-gray-400">角色演示、Cutscene 合集</p>
      </a>
      <a href="/news" class="block p-8 bg-gray-800 rounded-2xl hover:bg-gray-700 transition group">
        <div class="text-4xl mb-4">📰</div>
        <h3 class="text-xl font-bold mb-2 group-hover:text-xilian-purple">最新资讯</h3>
        <p class="text-gray-400">官方动态、活动信息</p>
      </a>
      <a href="/community" class="block p-8 bg-gray-800 rounded-2xl hover:bg-gray-700 transition group">
        <div class="text-4xl mb-4">💬</div>
        <h3 class="text-xl font-bold mb-2 group-hover:text-xilian-purple">粉丝社区</h3>
        <p class="text-gray-400">交流讨论、粉丝创作</p>
      </a>
      <div class="block p-8 bg-gray-800 rounded-2xl group">
        <div class="text-4xl mb-4">🛍️</div>
        <h3 class="text-xl font-bold mb-2 group-hover:text-xilian-purple">周边商品</h3>
        <p class="text-gray-400">即将上线</p>
      </div>
    </div>
  </section>

  <!-- Latest News Preview -->
  <section class="bg-gray-800/50 py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex justify-between items-center mb-12">
        <h2 class="text-4xl font-bold">最新资讯</h2>
        <a href="/news" class="text-xilian-purple hover:underline">查看全部 →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <article class="bg-gray-800 rounded-xl overflow-hidden hover:transform hover:scale-[1.02] transition">
          <div class="h-48 bg-gradient-to-br from-xilian-purple to-xilian-pink"></div>
          <div class="p-6">
            <span class="text-sm text-gray-400">2026-03-01</span>
            <h3 class="text-lg font-bold mt-2 mb-3">昔涟角色攻略</h3>
            <p class="text-gray-400 text-sm">全面解析昔涟的技能机制与配队建议...</p>
          </div>
        </article>
        <article class="bg-gray-800 rounded-xl overflow-hidden hover:transform hover:scale-[1.02] transition">
          <div class="h-48 bg-gradient-to-br from-xilian-blue to-xilian-purple"></div>
          <div class="p-6">
            <span class="text-sm text-gray-400">2026-02-15</span>
            <h3 class="text-lg font-bold mt-2 mb-3">来自星尘 4.0 版本</h3>
            <p class="text-gray-400 text-sm">新版本带来全新剧情与角色...</p>
          </div>
        </article>
        <article class="bg-gray-800 rounded-xl overflow-hidden hover:transform hover:scale-[1.02] transition">
          <div class="h-48 bg-gradient-to-br from-xilian-pink to-xilian-blue"></div>
          <div class="p-6">
            <span class="text-sm text-gray-400">2026-02-01</span>
            <h3 class="text-lg font-bold mt-2 mb-3">阿尔林铎探索指南</h3>
            <p class="text-gray-400 text-sm">新地图探索要点与隐藏要素...</p>
          </div>
        </article>
      </div>
    </div>
  </section>
</Layout>
