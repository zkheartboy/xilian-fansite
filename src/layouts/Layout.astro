---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "昔涟 Xilian 应援网站 - 来自星尘" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | 昔涟应援站</title>
  </head>
  <body class="bg-gray-900 text-gray-100 min-h-screen">
    <header class="fixed top-0 w-full bg-gray-900/90 backdrop-blur-sm z-50 border-b border-gray-800">
      <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="text-2xl font-bold bg-gradient-to-r from-xilian-purple to-xilian-pink bg-clip-text text-transparent">
          昔涟应援站
        </a>
        <ul class="flex gap-6">
          <li><a href="/" class="hover:text-xilian-purple transition">首页</a></li>
          <li><a href="/about" class="hover:text-xilian-purple transition">角色</a></li>
          <li><a href="/gallery" class="hover:text-xilian-purple transition">图库</a></li>
          <li><a href="/videos" class="hover:text-xilian-purple transition">视频</a></li>
          <li><a href="/news" class="hover:text-xilian-purple transition">资讯</a></li>
          <li><a href="/community" class="hover:text-xilian-purple transition">社区</a></li>
        </ul>
      </nav>
    </header>

    <main class="pt-20">
      <slot />
    </main>

    <footer class="bg-gray-800 py-8 mt-16">
      <div class="max-w-6xl mx-auto px-4 text-center text-gray-400">
        <p>© 2026 昔涟应援站 | 来自星尘</p>
        <p class="text-sm mt-2">本页面为粉丝制作，与米哈游官方无关</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body {
    font-family: 'Microsoft YaHei', 'PingFang SC', sans-serif;
  }
</style>
